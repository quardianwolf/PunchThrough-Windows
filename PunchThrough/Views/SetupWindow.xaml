<Window x:Class="PunchThrough.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PunchThrough Setup"
        Width="500" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="14" Margin="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F8F9FA" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.12" Color="#000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,32,0,8">
                <!-- Icon circle -->
                <Border Width="56" Height="56" CornerRadius="28" Margin="0,0,0,14"
                        HorizontalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4CAF50" Offset="0"/>
                            <GradientStop Color="#2E7D32" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="PT" FontSize="20" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="PunchThrough" FontSize="24" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                <TextBlock Text="Open-source DPI bypass tool" FontSize="12" Foreground="#999"
                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                <TextBlock x:Name="TxtSubtitle" Text="Setting up..." FontSize="12" Foreground="#4CAF50"
                           HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="Medium"/>
            </StackPanel>

            <!-- Steps -->
            <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="8" Margin="28,8,28,8" Padding="20,14">
                <StackPanel x:Name="StepList">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step1Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="Installing application" Grid.Column="1" Foreground="#555" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step2Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="Downloading SpoofDPI engine" Grid.Column="1" Foreground="#555" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step3Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="Creating desktop shortcut" Grid.Column="1" Foreground="#555" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Step4Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="Configuring auto-start" Grid.Column="1" Foreground="#555" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Progress bar -->
            <Border Grid.Row="2" Margin="28,4,28,12" CornerRadius="3" Background="#EEEEEE" Height="6">
                <Border x:Name="ProgressFill" CornerRadius="3" HorizontalAlignment="Left" Width="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4CAF50" Offset="0"/>
                            <GradientStop Color="#66BB6A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Border>

            <!-- Launch button -->
            <Button Grid.Row="3" x:Name="BtnClose" Content="Launch PunchThrough"
                    HorizontalAlignment="Center" Padding="36,10"
                    FontSize="13" FontWeight="Medium" Visibility="Collapsed"
                    Click="OnCloseClick"
                    Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4CAF50" Offset="0"/>
                        <GradientStop Color="#43A047" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Footer -->
            <StackPanel Grid.Row="4" HorizontalAlignment="Center" Margin="0,16,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#BBB">
                        <Hyperlink x:Name="LinkGitHub" RequestNavigate="OnLinkClick"
                                   NavigateUri="https://github.com/quardianwolf/PunchThrough-Windows"
                                   Foreground="#AAA" TextDecorations="None">
                            GitHub
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="  ·  " Foreground="#DDD" FontSize="11"/>
                    <TextBlock FontSize="11" Foreground="#BBB">
                        <Hyperlink x:Name="LinkSite" RequestNavigate="OnLinkClick"
                                   NavigateUri="https://atilla.dev"
                                   Foreground="#AAA" TextDecorations="None">
                            atilla.dev
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
