<Window x:Class="PunchThrough.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PunchThrough Setup"
        Width="520" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="14" Margin="16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F8F9FA" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.12" Color="#000"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,28,0,8">
                    <Border Width="52" Height="52" CornerRadius="26" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4CAF50" Offset="0"/>
                                <GradientStop Color="#2E7D32" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="PT" FontSize="18" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PunchThrough" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="#1A1A1A"/>
                    <TextBlock Text="Open-source DPI bypass tool" FontSize="11" Foreground="#999"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock x:Name="TxtSubtitle" Text="Choose your bypass mode" FontSize="12"
                               Foreground="#4CAF50" HorizontalAlignment="Center"
                               Margin="0,10,0,0" FontWeight="Medium"/>
                </StackPanel>

                <!-- Mode Selection (shown before install) -->
                <Border x:Name="ModePanel" Background="#FAFAFA" CornerRadius="8"
                        Margin="28,4,28,8" Padding="20,14">
                    <StackPanel>
                        <TextBlock Text="Bypass Mode" FontWeight="SemiBold" FontSize="13"
                                   Foreground="#333" Margin="0,0,0,10"/>

                        <RadioButton x:Name="RbFull" Content="Full Bypass" IsChecked="True"
                                     FontSize="12" Margin="0,0,0,2" GroupName="Mode"/>
                        <TextBlock Text="All HTTPS traffic is protected. Unblocks everything."
                                   FontSize="11" Foreground="#999" Margin="18,0,0,8"/>

                        <RadioButton x:Name="RbDiscord" Content="Discord Only"
                                     FontSize="12" Margin="0,0,0,2" GroupName="Mode"/>
                        <TextBlock Text="Only Discord is unblocked. Other apps unaffected."
                                   FontSize="11" Foreground="#999" Margin="18,0,0,8"/>

                        <RadioButton x:Name="RbCustom" Content="Custom"
                                     FontSize="12" Margin="0,0,0,2" GroupName="Mode"/>
                        <TextBlock Text="Choose which sites to unblock. Configurable in settings."
                                   FontSize="11" Foreground="#999" Margin="18,0,0,4"/>
                    </StackPanel>
                </Border>

                <!-- Steps (shown during install) -->
                <Border x:Name="StepsPanel" Background="#FAFAFA" CornerRadius="8"
                        Margin="28,4,28,8" Padding="20,14" Visibility="Collapsed">
                    <StackPanel x:Name="StepList">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Step1Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Text="Installing application" Grid.Column="1" Foreground="#555" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Step2Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Text="Extracting bypass engine" Grid.Column="1" Foreground="#555" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Step3Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Text="Creating desktop shortcut" Grid.Column="1" Foreground="#555" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Step4Icon" Text="&#x2022;" FontSize="14" Foreground="#CCC"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Text="Configuring auto-start" Grid.Column="1" Foreground="#555" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Progress bar -->
                <Border x:Name="ProgressPanel" Margin="28,4,28,8" CornerRadius="3"
                        Background="#EEEEEE" Height="6" Visibility="Collapsed">
                    <Border x:Name="ProgressFill" CornerRadius="3" HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#4CAF50" Offset="0"/>
                                <GradientStop Color="#66BB6A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>

                <!-- Install / Launch button -->
                <Button x:Name="BtnAction" Content="Install" HorizontalAlignment="Center"
                        Padding="40,10" Margin="0,8,0,0"
                        FontSize="13" FontWeight="Medium"
                        Click="OnActionClick"
                        Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#4CAF50" Offset="0"/>
                            <GradientStop Color="#43A047" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Footer -->
                <StackPanel HorizontalAlignment="Center" Margin="0,14,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="#BBB">
                            <Hyperlink x:Name="LinkGitHub" RequestNavigate="OnLinkClick"
                                       NavigateUri="https://github.com/quardianwolf/PunchThrough-Windows"
                                       Foreground="#AAA" TextDecorations="None">
                                GitHub
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Text="  ·  " Foreground="#DDD" FontSize="11"/>
                        <TextBlock FontSize="11" Foreground="#BBB">
                            <Hyperlink x:Name="LinkSite" RequestNavigate="OnLinkClick"
                                       NavigateUri="https://atilla.dev"
                                       Foreground="#AAA" TextDecorations="None">
                                atilla.dev
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
