<Window x:Class="PunchThrough.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PunchThrough Settings"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <TabControl Margin="8" x:Name="MainTabs">

        <!-- General Tab -->
        <TabItem x:Name="TabGeneral" Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <!-- Startup Section -->
                    <TextBlock Text="Startup" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkLaunchAtStartup" Content="Launch at Startup" Margin="0,0,0,4"
                              Checked="OnLaunchAtStartupChanged" Unchecked="OnLaunchAtStartupChanged"/>
                    <CheckBox x:Name="ChkAutoConnect" Content="Auto-connect on startup" Margin="0,0,0,16"
                              Checked="OnAutoConnectChanged" Unchecked="OnAutoConnectChanged"/>

                    <!-- Language Section -->
                    <TextBlock Text="Language" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <ComboBox x:Name="CmbLanguage" Width="200" HorizontalAlignment="Left" Margin="0,0,0,4"
                              SelectionChanged="OnLanguageChanged"/>
                    <TextBlock x:Name="TxtRestartHint" Text="Restart the app to apply language changes."
                               FontSize="11" Foreground="Gray" Margin="0,0,0,16"/>

                    <!-- Connection Status Section -->
                    <TextBlock Text="Connection" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status" Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtStatus" Foreground="Gray"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ConnectedInfo" Margin="0,0,0,4" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Method" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock x:Name="TxtMethod" Grid.Row="0" Grid.Column="1" Foreground="Gray"/>
                        <TextBlock Text="DNS" Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"/>
                        <TextBlock x:Name="TxtDns" Grid.Row="1" Grid.Column="1" Foreground="Gray" Margin="0,4,0,0"/>
                    </Grid>

                    <!-- About Section -->
                    <TextBlock Text="About" FontWeight="SemiBold" FontSize="13" Margin="0,16,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PunchThrough for Windows" Grid.Column="0"/>
                        <TextBlock Text="v1.0.0" Foreground="Gray" Grid.Column="1"/>
                    </Grid>
                    <TextBlock>
                        <Hyperlink x:Name="GitHubLink" RequestNavigate="OnGitHubLinkClick"
                                   NavigateUri="https://github.com/quardianwolf/PunchThrough-Windows">
                            GitHub Repository
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Bypass Tab -->
        <TabItem x:Name="TabBypass" Header="Bypass">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <!-- DNS Section -->
                    <TextBlock Text="DNS" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <ComboBox x:Name="CmbDnsServer" Width="200" HorizontalAlignment="Left" Margin="0,0,0,8"
                              SelectionChanged="OnDnsServerChanged"/>
                    <StackPanel x:Name="CustomDnsPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBox x:Name="TxtCustomDns" Width="200" HorizontalAlignment="Left"
                                 TextChanged="OnCustomDnsChanged"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkDoH" Content="Use DNS over HTTPS (DoH)" Margin="0,0,0,16"
                              Checked="OnDoHChanged" Unchecked="OnDoHChanged"/>

                    <!-- SpoofDPI Options -->
                    <TextBlock Text="SpoofDPI Options" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Port" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtPort" Width="80" Grid.Column="1"
                                 TextChanged="OnPortChanged"/>
                    </Grid>
                    <CheckBox x:Name="ChkSystemProxy" Content="Configure System Proxy" Margin="0,0,0,4"
                              Checked="OnSystemProxyChanged" Unchecked="OnSystemProxyChanged"/>
                    <TextBlock Text="System proxy will route traffic through SpoofDPI automatically."
                               FontSize="11" Foreground="Gray" Margin="0,0,0,16"/>

                    <!-- Installation Status -->
                    <TextBlock Text="Installation Status" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="SpoofDPI" Margin="0,0,12,0"/>
                        <Ellipse x:Name="InstallDot" Width="10" Height="10" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TxtInstallStatus" Foreground="Gray"/>
                    </StackPanel>
                    <StackPanel x:Name="InstallHintPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,0,0">
                        <TextBlock Text="scoop install spoofdpi" FontFamily="Consolas" FontSize="11" Foreground="Gray" Margin="0,0,8,0"/>
                        <Button Content="Copy" FontSize="11" Padding="8,2" Click="OnCopyInstallCommand"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Logs Tab -->
        <TabItem x:Name="TabLogs" Header="Logs">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Log list or empty state -->
                <ListBox x:Name="LogList" Grid.Row="0" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding LevelIcon}" Width="20" FontSize="12"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Message}" FontFamily="Consolas" FontSize="11"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                               FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="TxtNoLogs" Grid.Row="0"
                           Text="No Logs" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="14" Visibility="Visible"/>

                <!-- Footer -->
                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#DDD" Padding="8,6">
                    <Grid>
                        <TextBlock x:Name="TxtLogCount" Text="0 entries" Foreground="Gray" FontSize="11"/>
                        <Button x:Name="BtnClearLogs" Content="Clear Logs" HorizontalAlignment="Right"
                                FontSize="11" Padding="8,2" Click="OnClearLogs"/>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
